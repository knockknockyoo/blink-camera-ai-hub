# 5분마다 새 Blink 영상을 확인합니다.
SCAN_INTERVAL_SECONDS=300

# 같은 카메라에서 2분 안에 이어진 클립을 한 사건 영상으로 묶습니다.
MERGE_WINDOW_SECONDS=120

# 원본·제외·이벤트 영상을 보관할 기간입니다. 0이면 자동 삭제하지 않습니다.
VIDEO_RETENTION_DAYS=90

# Blink 앱의 카메라 이름. 모든 카메라는 all입니다.
BLINK_CAMERA=all

# AI 분석 설정
MODEL_NAME=yolo11n.pt
DETECTION_CONFIDENCE=0.15
SAMPLE_FPS=5
CAMERA_TIMEZONE=Asia/Seoul
PERSON_MIN_AREA=0.004
PERSON_MIN_BOX_MOTION=0.06
# 이미 주차된 차량은 무시하고 차량 영역이 실제로 움직일 때만 감지합니다.
VEHICLE_MIN_BOX_MOTION=0.01
# 초점 밖 벌레를 차량으로 오인하지 않도록 차량 박스의 최소 선명도를 검사합니다.
VEHICLE_MIN_SHARPNESS=700
KEEP_UNKNOWN_MOTION=false

# Telegram Bot API
# 실제 토큰과 chat ID는 .env에만 넣고 GitHub 이슈나 로그에 공개하지 마세요.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
TELEGRAM_PROTECT_CONTENT=true

# Blink 인증 전 화면만 시험하려면 true로 둡니다.
DEMO_MODE=false
