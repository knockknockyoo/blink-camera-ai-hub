# Check for new Blink videos every five minutes.
SCAN_INTERVAL_SECONDS=300

# Merge clips from the same camera within two minutes into one event video.
MERGE_WINDOW_SECONDS=120

# Number of days to retain raw, rejected, and event videos. Use 0 to disable cleanup.
VIDEO_RETENTION_DAYS=90

# Camera name from the Blink app. Use all for every camera.
BLINK_CAMERA=all

# Prevent one slow Blink clip from blocking the entire scan.
BLINK_CLIP_TIMEOUT_SECONDS=90
# Limit Blink login, refresh, and Sync Module manifest operations.
BLINK_METADATA_TIMEOUT_SECONDS=120
# Try once per scan and retry failed clips during the next scan.
BLINK_DOWNLOAD_RETRIES=1
# Process this many newest clips per scan. Use 0 for no limit.
BLINK_MAX_CLIPS_PER_SCAN=20
# Delay between clips to reduce Blink API throttling.
BLINK_DOWNLOAD_DELAY_SECONDS=5
# Retry an unfinished download backlog without waiting for the normal scan interval.
BLINK_BACKLOG_RETRY_SECONDS=15
# Recheck the previous 15 minutes so clips that reach Sync Module storage late are not missed.
BLINK_SCAN_OVERLAP_SECONDS=900

# AI analysis
# Process all completed downloads every five minutes.
ANALYSIS_INTERVAL_SECONDS=300
MODEL_NAME=yolo11n.pt
DETECTION_CONFIDENCE=0.15
SAMPLE_FPS=5
CAMERA_TIMEZONE=Asia/Seoul
PERSON_MIN_AREA=0.004
PERSON_MIN_BOX_MOTION=0.06
# Ignore parked vehicles and keep only vehicle regions that actually move.
VEHICLE_MIN_BOX_MOTION=0.01
# Require minimum sharpness so out-of-focus insects are not mistaken for vehicles.
VEHICLE_MIN_SHARPNESS=700
KEEP_UNKNOWN_MOTION=false

# Telegram Bot API
# Store real tokens and chat IDs only in .env. Never publish them in issues or logs.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
TELEGRAM_PROTECT_CONTENT=true

# Set true to preview the dashboard before connecting Blink.
DEMO_MODE=false
